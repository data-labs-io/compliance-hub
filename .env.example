# =============================================================================
# Fabric Pulse - Environment Configuration
# =============================================================================
# Copy this file to .env and configure the required values.
# =============================================================================

# -----------------------------------------------------------------------------
# Optional: Pre-configured IP Fabric Instance (Standalone)
# -----------------------------------------------------------------------------
# If set, the login page will be bypassed or pre-filled.
# IPF_API_URL=https://your-instance.ipfabric.io
# IPF_API_TOKEN=your-api-token

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
NODE_ENV=development
